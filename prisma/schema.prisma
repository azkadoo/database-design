// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Admin {
  id Int @id @default(autoincrement())
  email String @unique
  name String
  password String
}

model Customer {
  id          Int      @id @default(autoincrement())
  name        String
  phoneNumber String
  address     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  order    Order[] // state a foreign key to product, satu customer bisa punya banyak order
  cartItem CartItem[] // state a foreign key to cartItem, satu customer bisa punya banyak cartItem
  review   Review[]
}

model Category {
  id          Int     @id @default(autoincrement())
  name        String
  description String?

  product Product[] // state a foreign key to product, satu category bisa punya banyak product
}

model Product {
  id          Int    @id @default(autoincrement())
  name        String
  description String
  price       Int
  size        String

  cartItem CartItem[]

  categoryId Int // define attribut foreign key dari product
  category   Category @relation(fields: [categoryId], references: [id]) // ambil relation dari category

  review Review[]
}

model Order {
  id        Int      @id @default(autoincrement())
  status    String
  createdAt DateTime

  customerId Int // define attribute foreign key dari customer
  customer   Customer @relation(fields: [customerId], references: [id]) // ambil relation dari customer

  orderItems OrderItem[] // state a foreign key to orderItem, satu Order bisa punya banyak orderItem
}

model OrderItem {
  id    Int @id @default(autoincrement())
  qty   Int
  price Int

  OrderId Int // define attribut foreign key dari Order
  order   Order @relation(fields: [OrderId], references: [id]) // ambil relation dari order
}

model Review {
  id     Int    @id @default(autoincrement())
  rating Int
  review String

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id])
}

model CartItem {
  id  Int @id @default(autoincrement())
  qty Int

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id])
}
